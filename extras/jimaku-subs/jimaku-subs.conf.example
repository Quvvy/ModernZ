# Jimaku API key from https://jimaku.cc/account
# Copy this file to mpv script-opts/jimaku-subs.conf and set your key locally.
# NEVER commit jimaku-subs.conf to git.
api_key=YOUR_KEY_HERE

# Automatically fetch subs when a file/stream opens
auto_fetch=yes

# Preferred subtitle language tag for auto-selection
language_preference=ja

# Where to store subs for streams (~~ = home directory)
cache_dir=~~/mpv_subs

# Jimaku API base URL
api_base_url=https://jimaku.cc

# Delay before auto-fetch (ms), allows Seanime to set media-title
auto_fetch_delay_ms=800
