# mpvacious mining config for ModernZ sentence-first mining.
# Copy to portable_config/script-opts/subs2srs.conf (installer may create a default; merge these settings).

deck_name=Anime::Mining
model_name=ModernZ Mining Sentence
sentence_field=SentKanji
secondary_field=SentEng
audio_field=SentAudio
image_field=Image
note_tag=anime mining %d
menu_font_size=24
menu_font_name=Segoe UI
ankiconnect_url=127.0.0.1:8765
use_ffmpeg=no
create_deck=yes
allow_duplicates=yes
nuke_spaces=yes
snapshot_format=webp
secondary_sub_auto_load=yes
secondary_sub_lang=eng,en
secondary_sub_visibility=auto
enable_new_note_timer=yes

# Optional Yomitan workflow: copy JP subs to clipboard as they appear.
autoclip=yes
autoclip_method=clipboard

# Slightly wider audio clips around dialogue (helps debrid streams)
audio_padding=0.3

# Play clip after note creation to confirm audio was cut correctly
preview_audio=yes
